{
  // ─── Properties ──────────────────────────────────────────────────────────────

  "Auto property": {
    "prefix": "prop",
    "body": ["public ${1:int} ${2:Name} { get; set; }$0"],
    "description": "Auto-implemented property"
  },
  "Auto property with init": {
    "prefix": "propi",
    "body": ["public ${1:int} ${2:Name} { get; init; }$0"],
    "description": "Auto-implemented init-only property"
  },
  "Auto property readonly": {
    "prefix": "propr",
    "body": ["public ${1:int} ${2:Name} { get; }$0"],
    "description": "Read-only auto-implemented property"
  },
  "Full property with backing field": {
    "prefix": "propfull",
    "body": [
      "private ${1:int} _${2:name};",
      "",
      "public ${1:int} ${3:Name}",
      "{",
      "    get => _${2:name};",
      "    set => _${2:name} = value;",
      "}$0"
    ],
    "description": "Full property with backing field"
  },

  // ─── Constructors / Patterns ──────────────────────────────────────────────────

  "Constructor": {
    "prefix": "ctor",
    "body": [
      "public ${1:ClassName}(${2})",
      "{",
      "    $0",
      "}"
    ],
    "description": "Constructor"
  },

  // ─── Classes ──────────────────────────────────────────────────────────────────

  "Class": {
    "prefix": "class",
    "body": [
      "public class ${1:ClassName}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Class declaration"
  },
  "Sealed class": {
    "prefix": "classs",
    "body": [
      "public sealed class ${1:ClassName}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Sealed class declaration"
  },
  "Interface": {
    "prefix": "interface",
    "body": [
      "public interface I${1:Name}",
      "{",
      "    $0",
      "}"
    ],
    "description": "Interface declaration"
  },
  "Record": {
    "prefix": "record",
    "body": ["public record ${1:Name}(${2});$0"],
    "description": "Record type"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "public enum ${1:Name}",
      "{",
      "    ${2:Value1},$0",
      "}"
    ],
    "description": "Enum declaration"
  },

  // ─── Methods ──────────────────────────────────────────────────────────────────

  "Method": {
    "prefix": "meth",
    "body": [
      "public ${1:void} ${2:MethodName}(${3})",
      "{",
      "    $0",
      "}"
    ],
    "description": "Method declaration"
  },
  "Async method": {
    "prefix": "methа",
    "body": [
      "public async Task${1:<${2:TResult}>} ${3:MethodName}(${4})",
      "{",
      "    $0",
      "}"
    ],
    "description": "Async method declaration"
  },
  "Override method": {
    "prefix": "overr",
    "body": [
      "public override ${1:void} ${2:MethodName}(${3})",
      "{",
      "    $0",
      "}"
    ],
    "description": "Override method"
  },

  // ─── Control flow ─────────────────────────────────────────────────────────────

  "If statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition})",
      "{",
      "    $0",
      "}"
    ],
    "description": "If statement"
  },
  "If-else statement": {
    "prefix": "ife",
    "body": [
      "if (${1:condition})",
      "{",
      "    $2",
      "}",
      "else",
      "{",
      "    $0",
      "}"
    ],
    "description": "If-else statement"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for (int ${1:i} = 0; ${1:i} < ${2:count}; ${1:i}++)",
      "{",
      "    $0",
      "}"
    ],
    "description": "For loop"
  },
  "Foreach loop": {
    "prefix": "foreach",
    "body": [
      "foreach (${1:var} ${2:item} in ${3:collection})",
      "{",
      "    $0",
      "}"
    ],
    "description": "Foreach loop"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition})",
      "{",
      "    $0",
      "}"
    ],
    "description": "While loop"
  },
  "Switch statement": {
    "prefix": "switch",
    "body": [
      "switch (${1:variable})",
      "{",
      "    case ${2:value}:",
      "        $3",
      "        break;",
      "    default:",
      "        $0",
      "        break;",
      "}"
    ],
    "description": "Switch statement"
  },
  "Switch expression": {
    "prefix": "switche",
    "body": [
      "${1:variable} switch",
      "{",
      "    ${2:pattern} => ${3:result},",
      "    _ => $0",
      "};"
    ],
    "description": "Switch expression"
  },
  "Try-catch": {
    "prefix": "try",
    "body": [
      "try",
      "{",
      "    $1",
      "}",
      "catch (${2:Exception} ${3:ex})",
      "{",
      "    $0",
      "}"
    ],
    "description": "Try-catch block"
  },
  "Try-catch-finally": {
    "prefix": "tryf",
    "body": [
      "try",
      "{",
      "    $1",
      "}",
      "catch (${2:Exception} ${3:ex})",
      "{",
      "    $4",
      "}",
      "finally",
      "{",
      "    $0",
      "}"
    ],
    "description": "Try-catch-finally block"
  },

  // ─── Null checks / Guards ─────────────────────────────────────────────────────

  "Null check throw": {
    "prefix": "null",
    "body": [
      "if (${1:value} is null)",
      "    throw new ArgumentNullException(nameof(${1:value}));"
    ],
    "description": "Null check with ArgumentNullException"
  },
  "ArgumentNullException.ThrowIfNull": {
    "prefix": "nullt",
    "body": ["ArgumentNullException.ThrowIfNull(${1:value});$0"],
    "description": "ArgumentNullException.ThrowIfNull (C# 10+)"
  },
  "Null coalescing throw": {
    "prefix": "nullc",
    "body": ["${1:value} ?? throw new ArgumentNullException(nameof(${1:value}));$0"],
    "description": "Null coalescing throw"
  },
  "Pattern match not null": {
    "prefix": "notnull",
    "body": ["if (${1:value} is not null)", "{", "    $0", "}"],
    "description": "Pattern match not null"
  },

  // ─── Console / Debug ──────────────────────────────────────────────────────────

  "Console.WriteLine": {
    "prefix": "cw",
    "body": ["Console.WriteLine(${1});$0"],
    "description": "Console.WriteLine"
  },
  "Console.WriteLine interpolated": {
    "prefix": "cwi",
    "body": ["Console.WriteLine(\\$\"{${1}}\");$0"],
    "description": "Console.WriteLine with interpolated string"
  },

  // ─── Logging (Microsoft.Extensions.Logging) ───────────────────────────────────

  "Logger field": {
    "prefix": "logger",
    "body": [
      "private readonly ILogger<${1:ClassName}> _logger;"
    ],
    "description": "ILogger field"
  },
  "Log information": {
    "prefix": "logi",
    "body": ["_logger.LogInformation(\"${1:Message}\");$0"],
    "description": "Log information"
  },
  "Log warning": {
    "prefix": "logw",
    "body": ["_logger.LogWarning(\"${1:Message}\");$0"],
    "description": "Log warning"
  },
  "Log error": {
    "prefix": "loge",
    "body": ["_logger.LogError(${2:ex}, \"${1:Message}\");$0"],
    "description": "Log error with exception"
  },

  // ─── Async / Task ─────────────────────────────────────────────────────────────

  "Await": {
    "prefix": "await",
    "body": ["await ${1:task};$0"],
    "description": "Await expression"
  },
  "Task.FromResult": {
    "prefix": "tfr",
    "body": ["Task.FromResult(${1:value})$0"],
    "description": "Task.FromResult"
  },
  "CancellationToken parameter": {
    "prefix": "ct",
    "body": ["CancellationToken ${1:cancellationToken} = default"],
    "description": "CancellationToken parameter"
  },

  // ─── LINQ ─────────────────────────────────────────────────────────────────────

  "LINQ Where": {
    "prefix": "lw",
    "body": [".Where(${1:x} => ${2:condition})$0"],
    "description": "LINQ Where"
  },
  "LINQ Select": {
    "prefix": "ls",
    "body": [".Select(${1:x} => ${2:x})$0"],
    "description": "LINQ Select"
  },
  "LINQ FirstOrDefault": {
    "prefix": "lfo",
    "body": [".FirstOrDefault(${1:x} => ${2:condition})$0"],
    "description": "LINQ FirstOrDefault"
  },
  "LINQ ToList": {
    "prefix": "ltl",
    "body": [".ToList()$0"],
    "description": "LINQ ToList"
  },
  "LINQ ToArray": {
    "prefix": "lta",
    "body": [".ToArray()$0"],
    "description": "LINQ ToArray"
  },

  // ─── Dependency Injection (constructor pattern) ───────────────────────────────

  "DI field + ctor param": {
    "prefix": "di",
    "body": [
      "private readonly ${1:IService} _${2:service};"
    ],
    "description": "Readonly DI field"
  },

  // ─── Attributes ───────────────────────────────────────────────────────────────

  "Obsolete attribute": {
    "prefix": "obs",
    "body": ["[Obsolete(\"${1:Use X instead.}\")]$0"],
    "description": "Obsolete attribute"
  },

  // ─── XML doc comments ─────────────────────────────────────────────────────────

  "XML doc summary": {
    "prefix": "///",
    "body": [
      "/// <summary>",
      "/// $1",
      "/// </summary>$0"
    ],
    "description": "XML doc summary comment"
  },
  "XML doc param": {
    "prefix": "///p",
    "body": ["/// <param name=\"${1:paramName}\">${2}</param>$0"],
    "description": "XML doc param"
  },
  "XML doc returns": {
    "prefix": "///r",
    "body": ["/// <returns>${1}</returns>$0"],
    "description": "XML doc returns"
  }
}
