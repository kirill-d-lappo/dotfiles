{
  "window.titleBarStyle": "custom",
  "editor.fontFamily": "'FiraCode Nerd Font','Droid Sans Mono', 'monospace', monospace",
  "editor.renderWhitespace": "trailing",
  "files.trimTrailingWhitespace": true,
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "redhat.telemetry.enabled": false,
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "explorer.confirmDelete": false,
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "editor.inlineSuggest.enabled": true,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "log.error",
        "settings": {
          "foreground": "#af1f1f",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "log.warning",
        "settings": {
          "foreground": "#f4ad42"
        }
      },
      {
        "scope": "log.info",
        "settings": {
          "foreground": "#66D3FA"
        }
      },
      {
        "scope": "log.date",
        "settings": {
          "foreground": "#418ba7",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "log.string",
        "settings": {
          "foreground": "#cfc45c"
        }
      },
      {
        "scope": "keyword.other.dotenv",
        "settings": {
          "foreground": "#FF000000"
        }
      }
    ]
  },
  "todo-tree.general.tags": [
    "todo",
    "bug",
    "fixme",
    "note"
  ],
  "todo-tree.regex.regexCaseSensitive": false,
  "todo-tree.highlights.defaultHighlight": {
    "foreground": "#F8DE7E",
    "icon": "file-directory",
    "type": "text"
  },
  "todo-tree.highlights.customHighlight": {
    "note": {
      "foreground": "#c4efff",
      "background": "#002c3a",
      "icon": "note"
    },
    "todo": {
      "foreground": "#22c4ff",
      "icon": "comment"
    },
    "fixme": {
      "foreground": "#FFA500",
      "icon": "flame"
    },
    "bug": {
      "foreground": "#E84855",
      "icon": "bug"
    }
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "mssql.connections": [],
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "workbench.editor.showTabs": "none",
  "workbench.colorTheme": "One Dark Vivid [Gen]",
  "editor.cursorSurroundingLinesStyle": "all",
  "editor.cursorSurroundingLines": 1,
  "files.associations": {
    "*.csproj": "xml",
    ".env*": "dotenv"
  },
  "csharp.debug.justMyCode": false,
  "terminal.integrated.commandsToSkipShell": [
    "language-julia.interrupt"
  ],
  "julia.symbolCacheDownload": true,
  "julia.enableTelemetry": false,
  "markdown-preview-enhanced.previewTheme": "github-light.css",
  "window.dialogStyle": "custom",
  "[nginx]": {
    "editor.defaultFormatter": "raynigon.nginx-formatter"
  },
  "powershell.promptToUpdatePowerShell": false,
  "csv-edit.disableBorders": true,
  "csv-edit.writeOption_hasHeader": "true",
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "github.copilot.nextEditSuggestions.enabled": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.startupEditor": "none",
  "julia.enableCrashReporter": false,
  "json.schemaDownload.trustedDomains": {
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://models.dev/model-schema.json": true,
    "https://opencode.ai/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://www.schemastore.org/": true
  },
  "[shellscript]": {
    "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
  },
  "cSpell.userWords": [
    "envsubst",
    "healthcheck",
    "klappo",
    "Laravel",
    "Ledning",
    "RECAPTCHA",
    "sendgrid",
    "Timecheck",
    "timetjek",
    "VITE",
    "WWWGROUP",
    "WWWUSER"
  ],
  "powershell.debugging.createTemporaryIntegratedConsole": true,
  "terminal.integrated.defaultProfile.linux": "bash",
  "editor.formatOnSave": true,
  "laravel-pint.enable": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 2000,
  "workbench.activityBar.location": "top"
}