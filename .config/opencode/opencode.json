{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "enabled_providers": ["github-copilot"],
  "permission": {
    "external_directory": {
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "awk *": "allow",
      "basename *": "allow",
      "cat *": "allow",
      "cp *": "allow",
      "curl *": "allow",
      "date *": "allow",
      "dirname *": "allow",
      "dotnet *": "allow",
      "env *": "allow",
      "echo *": "allow",
      "false": "allow",
      "find *": "allow",
      "gh *": "allow",
      "git *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "mv *": "ask",
      "npm *": "allow",
      "nohup *": "allow",
      "rg *": "allow",
      "rm *": "ask",
      "sed *": "allow",
      "sort *": "allow",
      "sleep *": "allow",
      "tail *": "allow",
      "tee *": "allow",
      "test *": "allow",
      "tree": "allow",
      "true": "allow",
      "python": "allow",
      "python3": "allow",
      "pkill": "allow",
      "wc *": "allow",
      "xargs *": "allow",
      "git push *": "ask",
      "dotnet tool *": "ask",
      "kubectl *": "ask",
      "az *": "deny"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".vscode/**",
      ".idea/**",
      "*.log",
      "**/bin/**",
      "**/obj/**",
      ".venv/**",
      "target/release/**",
      "target/debug/**",
      "out/**"
    ]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}
